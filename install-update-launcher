#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

find_library() {
  local candidate
  for candidate in \
    "${INSTALL_UPDATE_LAUNCHER_LIB:-}" \
    "$SCRIPT_DIR/lib/install-update-launcher/install-update-launcher.bash" \
    "$SCRIPT_DIR/../lib/install-update-launcher/install-update-launcher.bash" \
    "$HOME/.local/lib/install-update-launcher/install-update-launcher.bash" \
    /usr/local/lib/install-update-launcher/install-update-launcher.bash; do
    [[ -n "$candidate" && -f "$candidate" ]] && { printf '%s\n' "$candidate"; return 0; }
  done
  return 1
}

LIBRARY="$(find_library)" || { echo "Erreur: bibliotheque install-update-launcher introuvable" >&2; exit 1; }
source "$LIBRARY"

IUL_PACKAGE_NAME="install-update-launcher"
IUL_COMMAND_NAME="install-update-launcher"
IUL_COMMAND_SOURCE="$SCRIPT_DIR/install-update-launcher"
IUL_MODULE_SOURCE_DIR="$SCRIPT_DIR/lib/install-update-launcher"
IUL_COMPLETION_SOURCE=""
IUL_CONFIG_DIR_FALLBACK=""
if [[ -f "$SCRIPT_DIR/deploy/manifest" ]]; then
  IUL_MANIFEST_SOURCE="$SCRIPT_DIR/deploy/manifest"
else
  IUL_MANIFEST_SOURCE="$(dirname "$LIBRARY")/deploy.manifest"
fi
IUL_REPOSITORY="${INSTALL_UPDATE_LAUNCHER_REPOSITORY:-https://github.com/dasbap/install-update-launcher.git}"
IUL_CHANNEL="${INSTALL_UPDATE_LAUNCHER_CHANNEL:-stable}"
IUL_REF="${INSTALL_UPDATE_LAUNCHER_REF:-}"

parse_deployment_options() {
  local option
  system=false
  while [[ $# -gt 0 ]]; do
    option="$1"; shift
    case "$option" in
      --system) system=true ;;
      --channel) [[ $# -gt 0 ]] || { echo "Error: --channel requires a value" >&2; exit 2; }; IUL_CHANNEL="$1"; shift ;;
      --ref) [[ $# -gt 0 ]] || { echo "Error: --ref requires a value" >&2; exit 2; }; IUL_REF="$1"; shift ;;
      --merge-config) IUL_MERGE_CONFIG=true ;;
      --force-config) IUL_FORCE_CONFIG=true ;;
      *) echo "Error: unknown deployment option: $option" >&2; exit 2 ;;
    esac
  done
  [[ -n "$IUL_REF" ]] || IUL_REF="$(iul_channel_ref "$IUL_CHANNEL")"
}

case "${1:-}" in
  --install|-i) shift; parse_deployment_options "$@"; iul_install "$system" ;;
  --update)
    shift; parse_deployment_options "$@"
    iul_apply_from_git update "$system" "$IUL_REPOSITORY" "$IUL_REF" \
      install-update-launcher install-update-launcher install-update-launcher \
      lib/install-update-launcher ""
    ;;
  --help|-h|"")
    printf 'Usage: install-update-launcher --install|--update [--system] [--channel stable|prerelease|development] [--ref git-ref] [--merge-config] [--force-config]\n'
    ;;
  *) echo "Erreur: option inconnue: $1" >&2; exit 1 ;;
esac
